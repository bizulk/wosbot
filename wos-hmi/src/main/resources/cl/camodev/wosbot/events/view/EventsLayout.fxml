<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<VBox maxHeight="1.7976931348623157E308" maxWidth="1.7976931348623157E308"
      HBox.hgrow="ALWAYS" VBox.vgrow="ALWAYS"
      xmlns="http://javafx.com/javafx/17.0.12" xmlns:fx="http://javafx.com/fxml/1">
    <children>
        <ScrollPane fitToWidth="true" hbarPolicy="NEVER" styleClass="task-page-scroll"
                    vbarPolicy="AS_NEEDED" VBox.vgrow="ALWAYS">
            <content>
                <VBox styleClass="task-page-root" maxHeight="1.7976931348623157E308"
                      maxWidth="1.7976931348623157E308">
                    <children>

                        <!-- Events Card: Tundra Truck -->
                        <VBox styleClass="content-card">
                            <children>
                                <HBox alignment="CENTER_LEFT" maxWidth="1.7976931348623157E308"
                                      styleClass="header-blue">
                                    <children>
                                        <CheckBox fx:id="checkBoxTundraEvent" mnemonicParsing="false"
                                                  style="-fx-font-weight: bold;" text="Tundra Truck Event" />
                                    </children>
                                </HBox>
                                <VBox styleClass="task-section-inner">
                                    <children>
                                        <Label styleClass="task-card-description"
                                               text="Automates truck refreshes and selections • Set activation time to run at specific hour"
                                               wrapText="true" />
                                        <Separator style="-fx-opacity: 0.25;" />
                                        <GridPane hgap="15" vgap="10">
                                            <columnConstraints>
                                                <ColumnConstraints percentWidth="50" />
                                                <ColumnConstraints percentWidth="50" />
                                            </columnConstraints>
                                            <rowConstraints>
                                                <RowConstraints />
                                                <RowConstraints />
                                            </rowConstraints>
                                            <children>
                                                <CheckBox fx:id="checkBoxTundraUseGems" mnemonicParsing="false" text="Use gems for refresh" GridPane.columnIndex="0" GridPane.rowIndex="0" />
                                                <CheckBox fx:id="checkBoxTundraSSR" mnemonicParsing="false" text="Go only for SSR trucks" GridPane.columnIndex="1" GridPane.rowIndex="0" />
                                                <CheckBox fx:id="checkBoxTundraEventActivationHour" mnemonicParsing="false" text="Use activation time" GridPane.columnIndex="0" GridPane.rowIndex="1" />
                                            </children>
                                        </GridPane>
                                        <HBox alignment="CENTER_LEFT" spacing="10">
                                            <children>
                                                <Label styleClass="task-field-label" minWidth="140.0" text="Activation time (UTC)" />
                                                <TextField fx:id="textfieldTundraActivationHour" prefWidth="80.0" promptText="HH:mm" />
                                            </children>
                                        </HBox>
                                        <Label fx:id="labelDateTimeError"
                                               style="-fx-font-size: 11px; -fx-text-fill: #ff4444;"
                                               text="" wrapText="true" />
                                    </children>
                                </VBox>
                            </children>
                        </VBox>

                        <!-- Events Card: Hero Mission -->
                        <VBox styleClass="content-card">
                            <children>
                                <HBox alignment="CENTER_LEFT" maxWidth="1.7976931348623157E308"
                                      styleClass="header-red">
                                    <children>
                                        <CheckBox fx:id="checkBoxHeroMission" mnemonicParsing="false"
                                                  style="-fx-font-weight: bold;" text="Hero's Mission Event" />
                                    </children>
                                </HBox>
                                <VBox styleClass="task-section-inner">
                                    <children>
                                        <Label styleClass="task-card-description"
                                               text="Call rallies on reapers to get season hero shards" wrapText="true" />
                                        <Separator style="-fx-opacity: 0.25;" />
                                        <HBox alignment="CENTER_LEFT" spacing="10">
                                            <children>
                                                <Label styleClass="task-field-label" minWidth="100.0" text="Flag Selection" />
                                                <ComboBox fx:id="comboBoxHeroMissionFlag" prefWidth="120.0" />
                                            </children>
                                        </HBox>
                                    </children>
                                </VBox>
                            </children>
                        </VBox>

                        <!-- Events Card: Mercenary -->
                        <VBox styleClass="content-card">
                            <children>
                                <HBox alignment="CENTER_LEFT" maxWidth="1.7976931348623157E308"
                                      styleClass="header-purple">
                                    <children>
                                        <CheckBox fx:id="checkBoxMercenaryEvent" mnemonicParsing="false"
                                                  style="-fx-font-weight: bold;" text="Mercenary Event" />
                                    </children>
                                </HBox>
                                <VBox styleClass="task-section-inner">
                                    <children>
                                        <Label styleClass="task-card-description"
                                               text="Automatically hunt mercenaries" wrapText="true" />
                                        <Separator style="-fx-opacity: 0.25;" />
                                        <HBox fx:id="hboxMercenaryFlagSelection" alignment="CENTER_LEFT" spacing="10">
                                            <children>
                                                <Label styleClass="task-field-label" minWidth="100.0" text="Flag Selection" />
                                                <ComboBox fx:id="comboBoxMercenaryFlag" prefWidth="120.0" />
                                            </children>
                                        </HBox>
                                    </children>
                                </VBox>
                            </children>
                        </VBox>

                        <!-- Events Card: Journey of Light -->
                        <VBox styleClass="content-card">
                            <children>
                                <HBox alignment="CENTER_LEFT" maxWidth="1.7976931348623157E308"
                                      styleClass="header-yellow">
                                    <children>
                                        <CheckBox fx:id="checkBoxJourneyofLight" mnemonicParsing="false"
                                                  style="-fx-font-weight: bold;" text="Journey of Light" />
                                    </children>
                                </HBox>
                                <VBox styleClass="task-section-inner">
                                    <children>
                                        <Label styleClass="task-card-description"
                                               text="Automatically participate in Journey of Light event" wrapText="true" />
                                        <Separator style="-fx-opacity: 0.25;" />
                                        <Label styleClass="task-card-description"
                                               style="-fx-font-style: italic;"
                                               text="No additional configuration required" wrapText="true" />
                                    </children>
                                </VBox>
                            </children>
                        </VBox>

                        <!-- Events Card: Myriad Bazaar -->
                        <VBox styleClass="content-card">
                            <children>
                                <HBox alignment="CENTER_LEFT" maxWidth="1.7976931348623157E308"
                                      styleClass="header-green">
                                    <children>
                                        <CheckBox fx:id="checkBoxMyriadBazaar" mnemonicParsing="false"
                                                  style="-fx-font-weight: bold;" text="Myriad Bazaar" />
                                    </children>
                                </HBox>
                                <VBox styleClass="task-section-inner">
                                    <children>
                                        <Label styleClass="task-card-description"
                                               text="Automatically collect daily free rewards from Myriad Bazaar" wrapText="true" />
                                        <Separator style="-fx-opacity: 0.25;" />
                                        <Label styleClass="task-card-description"
                                               style="-fx-font-style: italic;"
                                               text="No additional configuration required" wrapText="true" />
                                    </children>
                                </VBox>
                            </children>
                        </VBox>

                    </children>
                </VBox>
            </content>
        </ScrollPane>
    </children>
</VBox>
