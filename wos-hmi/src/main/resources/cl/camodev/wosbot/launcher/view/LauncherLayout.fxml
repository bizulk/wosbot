<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.*?>
<?import javafx.scene.control.*?>
<?import javafx.scene.image.*?>
<?import javafx.scene.layout.*?>

<BorderPane xmlns="http://javafx.com/javafx/23.0.1" xmlns:fx="http://javafx.com/fxml/1"
            maxHeight="1.7976931348623157E308" maxWidth="1.7976931348623157E308"
            style="-fx-background-color: #11141a; -fx-border-color: #30363d; -fx-border-width: 1;">

    <!-- ======================== TOP: CUSTOM TITLE BAR ======================== -->
    <top>
        <StackPane fx:id="titleBar" minHeight="32" prefHeight="32" maxHeight="32"
                   styleClass="custom-title-bar"
                   onMousePressed="#handleTitleBarMousePressed"
                   onMouseDragged="#handleTitleBarMouseDragged"
                   onMouseReleased="#handleTitleBarMouseReleased"
                   onMouseClicked="#handleTitleBarMouseClicked">

            <!-- Title: always perfectly centered in the bar -->
            <Label fx:id="labelWindowTitle" text="Whiteout Survival Bot"
                   styleClass="title-bar-text"
                   StackPane.alignment="CENTER"
                   mouseTransparent="true" />

            <!-- Window Controls: pinned to right, non-blocking for drag -->
            <HBox alignment="CENTER_RIGHT" StackPane.alignment="CENTER_RIGHT" styleClass="title-bar-controls">
                <Button fx:id="btnMinimize" text="—" styleClass="title-bar-btn" onAction="#handleMinimize" focusTraversable="false" />
                <Button fx:id="btnMaximize" text="☐" styleClass="title-bar-btn" onAction="#handleMaximize" focusTraversable="false" />
                <Button fx:id="btnClose" text="✕" styleClass="title-bar-btn, title-bar-close" onAction="#handleClose" focusTraversable="false" />
            </HBox>
        </StackPane>
    </top>

    <!-- ======================== LEFT: SIDEBAR ======================== -->
    <left>
        <VBox styleClass="nav-sidebar">

            <!-- App Header (Logo / Title String) -->
        <VBox fx:id="sidebarHeader" alignment="CENTER" spacing="16" style="-fx-padding: 24 16 16 16;">
                <VBox fx:id="logoContainer" alignment="CENTER" style="-fx-cursor: hand; -fx-spacing: 0; -fx-padding: 0 0 4 0;" maxWidth="1.7976931348623157E308">
                    <Label id="logo-whiteout" text="WHITEOUT" />
                    <Label id="logo-survival" text="SURVIVAL" />
                </VBox>

                <!-- Profile Selector moved immediately below logo -->
                <VBox alignment="CENTER_LEFT" spacing="6" maxWidth="1.7976931348623157E308">
                    <Label text="Loaded profile" style="-fx-text-fill: #9eaab6; -fx-font-size: 11px; -fx-font-weight: bold;" />
                    <ComboBox fx:id="profileComboBox" maxWidth="1.7976931348623157E308" />
                </VBox>

                <!-- Search Bar -->
                <VBox maxWidth="1.7976931348623157E308">
                    <TextField fx:id="navSearchField" promptText="Search activities..." styleClass="search-field" maxWidth="1.7976931348623157E308" />
                </VBox>
            </VBox>

            <Separator styleClass="sidebar-divider" />

            <!-- Navigation Buttons — built dynamically by controller -->
            <ScrollPane hbarPolicy="NEVER" vbarPolicy="AS_NEEDED" fitToWidth="true"
                        VBox.vgrow="ALWAYS" style="-fx-background-color: transparent; -fx-background: transparent;">
                <VBox fx:id="buttonsContainer" styleClass="nav-button-container" spacing="8" />
            </ScrollPane>

            <Separator styleClass="sidebar-divider" />

            <!-- Pinned Navigation Buttons -->
            <VBox fx:id="pinnedButtonsContainer" styleClass="nav-button-container" spacing="8" style="-fx-padding: 0 0 16 0;" />

        </VBox>
    </left>

    <!-- ======================== CENTER: MAIN CONTENT ======================== -->
    <center>
        <StackPane fx:id="centerStack">
            <AnchorPane fx:id="mainContentPane"
                        style="-fx-background-color: #11141a;"
                        BorderPane.alignment="CENTER" />
        </StackPane>
    </center>

    <!-- ======================== BOTTOM: STATUS BAR ======================== -->
    <bottom>
        <HBox styleClass="status-bar" alignment="CENTER_LEFT" spacing="16">

            <!-- Left: Version and branding -->
            <HBox alignment="CENTER_LEFT" spacing="12">
                <Label fx:id="labelVersion" text="Whiteout Survival Bot" styleClass="app-version" style="-fx-text-fill: #e6edf3; -fx-font-weight: bold; -fx-font-size: 13px;" />
                <org.kordamp.ikonli.javafx.FontIcon fx:id="iconDiscord" iconSize="18" iconColor="#e6edf3" styleClass="social-icon" onMouseClicked="#openDiscord" style="-fx-cursor: hand;" />
                <org.kordamp.ikonli.javafx.FontIcon fx:id="iconGithub" iconSize="18" iconColor="#e6edf3" styleClass="social-icon" onMouseClicked="#openGithub" style="-fx-cursor: hand;" />
            </HBox>

            <!-- Spacer -->
            <Region HBox.hgrow="ALWAYS" />

            <!-- Right: Run Time + Actions -->
            <HBox alignment="CENTER" spacing="16">
                <Label fx:id="labelRunTime" text="Uptime: 00:00:00" style="-fx-text-fill: #e6edf3; -fx-font-size: 13px;" />
                
                <SplitMenuButton fx:id="buttonPauseResume" disable="true" mnemonicParsing="false"
                                 onAction="#handleButtonPauseResume" text="Pause"
                                 styleClass="action-button-pause" prefHeight="38" prefWidth="140">
                    <items>
                        <MenuItem fx:id="menuToggleCurrentQueue" onAction="#handleToggleCurrentQueue" text="Pause current queue" />
                        <MenuItem fx:id="menuToggleAllQueues" onAction="#handleToggleAllQueues" text="Pause all queues" />
                    </items>
                </SplitMenuButton>

                <Button fx:id="buttonStartStop" disable="true" mnemonicParsing="false"
                        onAction="#handleButtonStartStop" text="Start Bot"
                        styleClass="action-button-start" prefHeight="38" prefWidth="140" />
            </HBox>

        </HBox>
    </bottom>

</BorderPane>
