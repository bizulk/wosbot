<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<VBox maxHeight="1.7976931348623157E308" maxWidth="1.7976931348623157E308"
      HBox.hgrow="ALWAYS" VBox.vgrow="ALWAYS"
      xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1">
    <children>
        <ScrollPane fitToWidth="true" hbarPolicy="NEVER" styleClass="task-page-scroll"
                    vbarPolicy="AS_NEEDED" VBox.vgrow="ALWAYS">
            <content>
                <VBox styleClass="task-page-root" maxHeight="1.7976931348623157E308"
                      maxWidth="1.7976931348623157E308">
                    <children>

                        <!-- Create Character Card -->
                        <VBox styleClass="content-card">
                            <children>
                                <HBox alignment="CENTER_LEFT" maxWidth="1.7976931348623157E308"
                                      styleClass="header-green">
                                    <children>
                                        <Label text="Create Character Control" />
                                    </children>
                                </HBox>
                                <VBox styleClass="task-section-inner">
                                    <children>
                                        <Label styleClass="task-card-description"
                                               text="Creates a character based on Age restrictions." wrapText="true" />

                                        <Separator style="-fx-opacity: 0.25;" />

                                        <CheckBox fx:id="checkBoxEnableCreateCharacter" mnemonicParsing="false"
                                                  text="Enable Create Character Task" />
                                        <CheckBox fx:id="checkBoxSkipTutorial" mnemonicParsing="false"
                                                  text="Immediately skip tutorial" />

                                        <HBox alignment="CENTER_LEFT" spacing="10">
                                            <children>
                                                <Label styleClass="task-field-label" text="Maximum Age (minutes):" />
                                                <TextField fx:id="textFieldMaxAgeMinutes" prefWidth="100.0" promptText="17" />
                                            </children>
                                        </HBox>
                                    </children>
                                </VBox>
                            </children>
                        </VBox>

                    </children>
                </VBox>
            </content>
        </ScrollPane>
    </children>
</VBox>
