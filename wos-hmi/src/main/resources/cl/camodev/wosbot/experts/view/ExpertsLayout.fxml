<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import cl.camodev.wosbot.common.view.PriorityListView?>

<VBox maxHeight="1.7976931348623157E308" maxWidth="1.7976931348623157E308"
      HBox.hgrow="ALWAYS" VBox.vgrow="ALWAYS"
      xmlns="http://javafx.com/javafx/17.0.12" xmlns:fx="http://javafx.com/fxml/1">
    <children>
        <ScrollPane fitToWidth="true" hbarPolicy="NEVER"
                    styleClass="task-page-scroll" vbarPolicy="AS_NEEDED"
                    VBox.vgrow="ALWAYS">
            <content>
                <VBox styleClass="task-page-root" maxHeight="1.7976931348623157E308"
                      maxWidth="1.7976931348623157E308" VBox.vgrow="ALWAYS">
                    <children>

                        <!-- Experts Management Card -->
                        <VBox styleClass="content-card" VBox.vgrow="ALWAYS" maxHeight="1.7976931348623157E308">
                            <children>
                                <HBox alignment="CENTER_LEFT" maxWidth="1.7976931348623157E308"
                                      styleClass="header-purple">
                                    <children>
                                        <Label text="Experts Management" />
                                    </children>
                                </HBox>
                                <VBox styleClass="task-section-inner" VBox.vgrow="ALWAYS" maxHeight="1.7976931348623157E308">
                                    <children>
                                        <Label styleClass="task-card-description"
                                               text="Automates expert-related tasks and skill training" wrapText="true" />

                                        <Separator style="-fx-opacity: 0.25;" />

                                        <!-- Basic Tasks Sub-section -->
                                        <VBox styleClass="task-subsection">
                                            <children>
                                                <Label styleClass="task-subsection-title" text="Basic Tasks" />

                                                <CheckBox fx:id="claimIntelCheckBox" mnemonicParsing="false"
                                                          text="Claim new Intel from Agnes" />
                                                <CheckBox fx:id="claimLoyaltyTagCheckBox" mnemonicParsing="false"
                                                          text="Claim free loyalty tag from Romulus" />

                                                <HBox spacing="10">
                                                    <children>
                                                        <CheckBox fx:id="claimTroopsCheckBox" mnemonicParsing="false"
                                                                  text="Claim free troops from Romulus" />
                                                        <ComboBox fx:id="troopTypeComboBox" prefWidth="150.0" />
                                                    </children>
                                                </HBox>
                                            </children>
                                        </VBox>

                                        <Separator style="-fx-opacity: 0.25;" />

                                        <!-- Skill Training Sub-section -->
                                        <VBox spacing="10" VBox.vgrow="ALWAYS" maxHeight="1.7976931348623157E308">
                                            <children>
                                                <CheckBox fx:id="enableExpertSkillTrainingCheckBox" mnemonicParsing="false"
                                                          style="-fx-font-weight: bold;"
                                                          text="Enable Experts Skill Training" />

                                                <VBox fx:id="expertSkillTrainingVBox" styleClass="task-subsection"
                                                      VBox.vgrow="ALWAYS" maxHeight="1.7976931348623157E308">
                                                    <children>
                                                        <Label styleClass="task-subsection-title"
                                                               text="Expert Skills Training Priority:" />
                                                        <PriorityListView fx:id="expertSkillPriorities"
                                                                          VBox.vgrow="ALWAYS" maxHeight="1.7976931348623157E308" />
                                                    </children>
                                                </VBox>
                                            </children>
                                        </VBox>
                                    </children>
                                </VBox>
                            </children>
                        </VBox>

                    </children>
                </VBox>
            </content>
        </ScrollPane>
    </children>
</VBox>
