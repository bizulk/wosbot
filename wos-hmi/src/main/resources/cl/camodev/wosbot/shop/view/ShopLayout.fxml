<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<VBox maxHeight="1.7976931348623157E308" maxWidth="1.7976931348623157E308"
      HBox.hgrow="ALWAYS" VBox.vgrow="ALWAYS"
      xmlns="http://javafx.com/javafx/17.0.12" xmlns:fx="http://javafx.com/fxml/1">
    <children>
        <ScrollPane fitToWidth="true" hbarPolicy="NEVER"
                    styleClass="task-page-scroll" vbarPolicy="AS_NEEDED"
                    VBox.vgrow="ALWAYS">
            <content>
                <VBox styleClass="task-page-root" maxHeight="1.7976931348623157E308"
                      maxWidth="1.7976931348623157E308" VBox.vgrow="ALWAYS">
                    <children>

                        <!-- Nomadic Merchant Card -->
                        <VBox styleClass="content-card">
                            <children>
                                <HBox alignment="CENTER_LEFT" maxWidth="1.7976931348623157E308"
                                      styleClass="header-yellow">
                                    <children>
                                        <Label text="Nomadic Merchant" />
                                    </children>
                                </HBox>
                                <VBox styleClass="task-section-inner">
                                    <children>
                                        <Label styleClass="task-card-description"
                                               text="Configure purchases from the Nomadic Merchant shop" wrapText="true" />
                                        <Separator style="-fx-opacity: 0.25;" />
                                        <GridPane hgap="20" vgap="10">
                                            <columnConstraints>
                                                <ColumnConstraints percentWidth="50" />
                                                <ColumnConstraints percentWidth="50" />
                                            </columnConstraints>
                                            <rowConstraints>
                                                <RowConstraints />
                                            </rowConstraints>
                                            <children>
                                                <CheckBox fx:id="checkBoxNomadicMerchant" mnemonicParsing="false" text="Buy resources" GridPane.columnIndex="0" GridPane.rowIndex="0" />
                                                <CheckBox fx:id="checkBoxNomadicMerchantVip" mnemonicParsing="false" text="Buy VIP points" GridPane.columnIndex="1" GridPane.rowIndex="0" />
                                            </children>
                                        </GridPane>
                                    </children>
                                </VBox>
                            </children>
                        </VBox>

                        <!-- Bank Card -->
                        <VBox styleClass="content-card">
                            <children>
                                <HBox alignment="CENTER_LEFT" maxWidth="1.7976931348623157E308"
                                      styleClass="header-green">
                                    <children>
                                        <Label text="Enable Bank" />
                                    </children>
                                </HBox>
                                <VBox styleClass="task-section-inner">
                                    <children>
                                        <Label styleClass="task-card-description"
                                               text="Configure automatic bank transactions" wrapText="true" />
                                        <Separator style="-fx-opacity: 0.25;" />
                                        <CheckBox fx:id="checkBoxBank" mnemonicParsing="false" text="Enable Bank" />
                                        <Separator style="-fx-opacity: 0.25;" />
                                        <HBox spacing="10" alignment="CENTER_LEFT">
                                            <children>
                                                <Label styleClass="task-field-label" text="Period:" />
                                                <ComboBox fx:id="comboBoxBankDelay" prefWidth="150.0" promptText="Select period" />
                                            </children>
                                        </HBox>
                                    </children>
                                </VBox>
                            </children>
                        </VBox>

                        <!-- Mystery Shop Card -->
                        <VBox styleClass="content-card">
                            <children>
                                <HBox alignment="CENTER_LEFT" maxWidth="1.7976931348623157E308"
                                      styleClass="header-purple">
                                    <children>
                                        <Label text="Enable Mystery Shop" />
                                    </children>
                                </HBox>
                                <VBox styleClass="task-section-inner">
                                    <children>
                                        <Label styleClass="task-card-description"
                                               text="Configure automatic purchases from Mystery Shop" wrapText="true" />
                                        <Separator style="-fx-opacity: 0.25;" />
                                        <CheckBox fx:id="checkBoxMysteryShop" mnemonicParsing="false" text="Enable Mystery Shop" />
                                        <Separator style="-fx-opacity: 0.25;" />
                                        <CheckBox fx:id="checkBoxMysteryShop50DiscountGear" mnemonicParsing="false"
                                                  text="Buy 50% discounted hero gear (250 badges)" />
                                    </children>
                                </VBox>
                            </children>
                        </VBox>

                    </children>
                </VBox>
            </content>
        </ScrollPane>
    </children>
</VBox>
