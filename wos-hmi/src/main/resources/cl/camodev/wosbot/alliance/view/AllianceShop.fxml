<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import cl.camodev.wosbot.common.view.PriorityListView?>

<?import javafx.collections.FXCollections?>
<VBox maxHeight="1.7976931348623157E308" maxWidth="1.7976931348623157E308" HBox.hgrow="ALWAYS" VBox.vgrow="ALWAYS" xmlns="http://javafx.com/javafx/17.0.12" xmlns:fx="http://javafx.com/fxml/1">
    <children>
        <ScrollPane fitToWidth="true" hbarPolicy="NEVER" styleClass="task-page-scroll" vbarPolicy="AS_NEEDED" VBox.vgrow="ALWAYS">
            <content>
                <VBox styleClass="task-page-root" maxHeight="1.7976931348623157E308" maxWidth="1.7976931348623157E308" VBox.vgrow="ALWAYS">
                    <children>
                        <!-- Alliance Shop Card -->
                        <VBox styleClass="content-card" VBox.vgrow="ALWAYS" maxHeight="1.7976931348623157E308">
                            <children>
                                <HBox alignment="CENTER_LEFT" maxWidth="1.7976931348623157E308" styleClass="header-yellow">
                                    <children>
                                        <CheckBox fx:id="enableAllianceShopCheckbox" mnemonicParsing="false" text="Enable Alliance Shop" />
                                    </children>
                                </HBox>
                                <VBox styleClass="task-section-inner" VBox.vgrow="ALWAYS" maxHeight="1.7976931348623157E308">
                                    <children>
                                        <Label styleClass="task-card-description" text="Configure automated purchases from the Alliance Shop" wrapText="true" />
                                        
                                        <Separator style="-fx-opacity: 0.25;" />

                                        <!-- Alliance Coins Configuration Section -->
                                        <VBox styleClass="task-subsection">
                                            <children>
                                                <Label styleClass="task-subsection-title" text="Alliance Coins Configuration" />

                                                <HBox spacing="10" alignment="CENTER_LEFT">
                                                    <children>
                                                        <Label styleClass="task-field-label" text="Minimum Alliance Coins to Activate:" />
                                                        <TextField fx:id="minCoinsToActivateTextField" prefWidth="100" promptText="0" />
                                                        <Label styleClass="task-field-label" text="coins" />
                                                    </children>
                                                </HBox>

                                                <HBox spacing="10" alignment="CENTER_LEFT">
                                                    <children>
                                                        <Label styleClass="task-field-label" text="Minimum Alliance Coins to Save:" />
                                                        <TextField fx:id="minCoinsTextField" prefWidth="100" promptText="0" />
                                                        <Label styleClass="task-field-label" text="coins" />
                                                    </children>
                                                </HBox>

                                                <HBox spacing="10" alignment="CENTER_LEFT">
                                                    <children>
                                                        <Label styleClass="task-field-label" text="Minimum Discount Percentage to Purchase:" />
                                                        <ComboBox fx:id="minPercentageComboBox" prefWidth="100"/>
                                                        <Label styleClass="task-field-label" text="\%" />
                                                    </children>
                                                </HBox>
                                            </children>
                                        </VBox>

                                        <Label fx:id="instructionsLabel" wrapText="true"
                                               text="Define the priority order for purchases. Items with priority 1 will be purchased first. You can drag items to reorder or use the buttons. The minimum coins setting acts as a trigger - when Alliance Tech task runs and detects you have at least this amount, it will automatically schedule the Alliance Shop purchase task during bot execution."
                                               styleClass="task-card-note" />

                                        <!-- Priority List Section -->
                                        <VBox spacing="8" VBox.vgrow="ALWAYS" maxHeight="1.7976931348623157E308">
                                            <children>
                                                <Label styleClass="task-subsection-title" text="Purchase Priorities:" />
                                                <PriorityListView fx:id="allianceShopPriorities" VBox.vgrow="ALWAYS" maxHeight="1.7976931348623157E308" />
                                            </children>
                                        </VBox>
                                    </children>
                                </VBox>
                            </children>
                        </VBox>
                    </children>
                </VBox>
            </content>
        </ScrollPane>
    </children>
</VBox>
